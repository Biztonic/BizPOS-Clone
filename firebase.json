{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firebase_indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-functions-test"
      ]
    }
  ],
  "auth": {
    "providers": {
      "anonymous": true,
      "emailPassword": true
    }
  }
}
